# Public site URLs
NEXT_PUBLIC_SITE_URL=https://eclyps.vercel.app
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/eclyps.hub/

# Supabase public client values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Server-only Supabase key used for admin writes, server actions, sessions, and login rate limiting.
# Never expose this value in client code.
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key

# Admin auth
# Generate this from your admin password. Do not commit or deploy ADMIN_PASSWORD.
# Format: pbkdf2_sha256$iterations$salt$base64url-hash
ADMIN_PASSWORD_HASH=pbkdf2_sha256$310000$replace-with-random-salt$replace-with-base64url-hash

# Required for signed admin sessions. Must be at least 32 characters.
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

# Local development only, if you intentionally choose plain password login locally.
# Do not set ADMIN_PASSWORD in production.
# ADMIN_PASSWORD=local-dev-only-password
