# Public site URLs
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/your-profile/

# Supabase public client values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key_here

# Server-only Supabase key used for admin writes, server actions, sessions, and login rate limiting.
# Never expose this value in client code.
SUPABASE_SERVICE_ROLE_KEY=your_secret_service_role_key_here

# Admin auth
# Приклад валідного екранованого pbkdf2_sha256 хешу (замініть на власний)
ADMIN_PASSWORD_HASH=pbkdf2_sha256\$100000\$your_salt_here\$your_hash_here

# Required for signed admin sessions. Must be at least 32 characters.
ADMIN_SESSION_SECRET=your_random_32_character_secret_here

# Local development only, if you intentionally choose plain password login locally.
# Do not set ADMIN_PASSWORD in production.
# ADMIN_PASSWORD=local-dev-only-password

# Discord bot (optional) — used to send personal DM notifications to players.
# Players link their Discord account by logging in via Discord OAuth; the bot then
# DMs each user about invites, applications, match results, etc.
# Requirements: the bot must share a Discord server with the player and the player
# must have DMs enabled (Discord limitation). Leave empty to disable DM delivery.
# Create a bot at https://discord.com/developers/applications -> Bot -> Reset Token.
DISCORD_BOT_TOKEN=your_discord_bot_token_here
